# Copy to .env and fill in your values.

# --- Run mode ---
RUN_MODE=backtest          # backtest | live

# --- Alpaca (backtest / paper) ---
ALPACA_API_KEY_ID=
ALPACA_API_SECRET=
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex       # iex (free, ~2-3% of volume) | sip (paid, full market).
                           # Volume signals are calibrated for full volume — use sip if you can.

# --- Broker selection ---
BROKER=alpaca              # alpaca (default) | ibkr — ibkr needs TWS/IB Gateway running locally

# --- IBKR (live; used when BROKER=ibkr) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497             # 7497 = TWS paper, 7496 = TWS live, 4002 = Gateway paper, 4001 = Gateway live
IBKR_CLIENT_ID=1

# --- Liquid Co-Invest broker ---
USE_LIQUID_BROKER=false    # true to route orders through Liquid instead of IBKR
LIQUID_API_KEY=

# --- LLM (pick one — Gemini is free, Anthropic is paid) ---
# Gemini Flash: free tier (15 req/min, 1M tokens/day)
# Get key at: https://aistudio.google.com/app/apikey  (no credit card needed)
GEMINI_API_KEY=

# Anthropic Claude: paid API (~$0.0004/ticker for news, ~$0.006/ticker for vision)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
#LLM_VISION_MODEL=claude-sonnet-4-6   # chart-reading model (vision agent)
#GEMINI_MODEL=gemini-2.0-flash

# Priority: Gemini > Anthropic > keyword fallback (free, always works)

# --- News (optional, Alpaca news used if Alpaca keys set) ---
NEWS_API_KEY=

# --- Risk parameters ---
MAX_RISK_PER_TRADE_PCT=0.01
MIN_RISK_REWARD=1.5
MAX_POSITION_PCT=0.20
ATR_STOP_MULTIPLE=2.0
ATR_TARGET_MULTIPLE=3.0
MAX_OPEN_POSITIONS=5       # hard cap on concurrent open positions
MAX_DAILY_LOSS_PCT=0.03    # kill switch: halt new entries after -3% on the day

# --- Decision thresholds ---
LONG_THRESHOLD=60.0
SHORT_THRESHOLD=40.0
MIN_RISK_SCORE=35.0

# --- Execution ---
EXECUTE_LIVE=false         # must be explicitly true to send real orders in live mode

# --- Live runner ---
RESCAN_INTERVAL_MIN=30     # re-evaluate all tickers every N minutes in live_runner.py
EOD_FLATTEN=true           # close all positions before the bell (day-trade-only bot)
EOD_FLATTEN_MIN_BEFORE=5   # minutes before 16:00 ET to flatten

# --- Dashboard API server ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Vercel tunnel (optional) ---
# Free static domain from https://dashboard.ngrok.com/domains (e.g. yourname.ngrok-free.app).
# When set, START.bat opens a tunnel so the Vercel-hosted dashboard can reach this PC.
NGROK_DOMAIN=
