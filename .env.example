# Copy to .env and fill in your values.

# --- Run mode ---
RUN_MODE=backtest          # backtest | live

# --- Alpaca (backtest / paper) ---
ALPACA_API_KEY_ID=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# --- IBKR (live) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# --- Liquid Co-Invest broker ---
USE_LIQUID_BROKER=false    # true to route orders through Liquid instead of IBKR
LIQUID_API_KEY=

# --- AI4Trade social platform (https://ai4trade.ai) ---
AI4TRADE_EMAIL=            # creates an account on first run if it doesn't exist
AI4TRADE_PASSWORD=
AI4TRADE_BOT_NAME=tradingbot2026
AI4TRADE_PUBLISH=true      # publish signals + strategies to the community feed

# --- Anthropic LLM ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- News (optional, Alpaca news used if Alpaca keys set) ---
NEWS_API_KEY=

# --- Risk parameters ---
MAX_RISK_PER_TRADE_PCT=0.01
MIN_RISK_REWARD=1.5
MAX_POSITION_PCT=0.20
ATR_STOP_MULTIPLE=2.0
ATR_TARGET_MULTIPLE=3.0

# --- Decision thresholds ---
LONG_THRESHOLD=60.0
SHORT_THRESHOLD=40.0
MIN_RISK_SCORE=35.0

# --- Execution ---
EXECUTE_LIVE=false         # must be explicitly true to send real orders in live mode

# --- Live runner ---
RESCAN_INTERVAL_MIN=30     # re-evaluate all tickers every N minutes in live_runner.py
