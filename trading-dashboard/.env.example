# ── Alpaca (server-side only — NEVER prefix with NEXT_PUBLIC_) ──────────────
# Get from: https://app.alpaca.markets → API Keys
ALPACA_KEY_ID=your_alpaca_key_id
ALPACA_SECRET=your_alpaca_secret_key
ALPACA_PAPER=true          # true = paper trading account, false = live

# ── Bot FastAPI server URL ───────────────────────────────────────────────────
# Local dev:  http://localhost:8000
# Production: your Railway/Render URL
TRADING_BOT_API_URL=http://localhost:8000

# ── Expose bot URL to browser (for client-side refresh) ─────────────────────
NEXT_PUBLIC_BOT_API_URL=http://localhost:8000

# ── Database (Postgres — Vercel Postgres / Neon) ────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
